# mcp-citation-research environment variables
# Copy this file to .env and adjust to your deployment.

# Confidence gate threshold for citation verification (default: 0.90)
# CITATION_RESEARCH_GATE=0.90

# MCP server host and port (default: 127.0.0.1:8091)
# CITATION_MCP_HOST=127.0.0.1
# CITATION_MCP_PORT=8091

# URL of the citation research daemon (default: http://127.0.0.1:8090)
# CITATION_RESEARCHD_URL=http://127.0.0.1:8090

# Optional bearer token for daemon authentication (default: none)
# CITATION_RESEARCHD_TOKEN=
